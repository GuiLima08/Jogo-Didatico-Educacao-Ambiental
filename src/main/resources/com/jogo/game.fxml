<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" prefHeight="640" prefWidth="480.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jogo.Controller.GameController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="8.0" layoutY="7.0" prefHeight="626.0" prefWidth="463.0">
         <children>
            <HBox alignment="TOP_CENTER" prefHeight="138.0" prefWidth="463.0">
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
               <children>
                  <AnchorPane fx:id="healthPane" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white;">
                     <HBox.margin>
                        <Insets right="2.0" />
                     </HBox.margin>
                     <children>
                        <ImageView fitHeight="80.0" fitWidth="80.0" layoutX="5.0" layoutY="8.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/health.png" />
                           </image>
                        </ImageView>
                        <ProgressBar fx:id="hpBar" layoutX="2.0" layoutY="89.0" prefHeight="18.0" prefWidth="86.0" progress="0.0" />
                     </children>
                  </AnchorPane>
                  <AnchorPane fx:id="naturePane" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white;">
                     <HBox.margin>
                        <Insets right="2.0" />
                     </HBox.margin>
                     <children>
                        <ImageView fitHeight="80.0" fitWidth="80.0" layoutX="5.0" layoutY="7.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/tree.png" />
                           </image>
                        </ImageView>
                        <ProgressBar fx:id="natureBar" layoutX="2.0" layoutY="89.0" prefHeight="18.0" prefWidth="86.0" progress="0.0" />
                     </children>
                  </AnchorPane>
                  <AnchorPane fx:id="waterPane" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white;">
                     <HBox.margin>
                        <Insets right="2.0" />
                     </HBox.margin>
                     <children>
                        <ImageView fitHeight="80.0" fitWidth="80.0" layoutX="5.0" layoutY="8.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/water.png" />
                           </image>
                        </ImageView>
                        <ProgressBar fx:id="waterBar" layoutX="2.0" layoutY="89.0" prefHeight="18.0" prefWidth="86.0" progress="0.0" />
                     </children>
                  </AnchorPane>
                  <AnchorPane fx:id="peoplePane" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white;">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                     <children>
                        <ProgressBar fx:id="peopleBar" layoutX="2.0" layoutY="89.0" prefHeight="18.0" prefWidth="86.0" progress="0.0" />
                        <ImageView fitHeight="80.0" fitWidth="80.0" layoutX="6.0" layoutY="7.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/people.png" />
                           </image>
                        </ImageView>
                     </children>
                  </AnchorPane>
                  <AnchorPane fx:id="moneyPane" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: white;">
                     <HBox.margin>
                        <Insets left="2.0" />
                     </HBox.margin>
                     <children>
                        <ImageView fitHeight="80.0" fitWidth="80.0" layoutX="6.0" layoutY="8.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/money.png" />
                           </image>
                        </ImageView>
                        <ProgressBar fx:id="moneyBar" layoutX="3.0" layoutY="89.0" prefHeight="18.0" prefWidth="86.0" progress="0.0" />
                     </children>
                  </AnchorPane>
               </children>
            </HBox>
            <Separator prefHeight="0.0" prefWidth="463.0" />
            <StackPane prefHeight="482.0" prefWidth="463.0">
               <children>
                  <VBox fx:id="choiceVBox" alignment="CENTER" disable="true" prefHeight="535.0" prefWidth="463.0" visible="false">
                     <children>
                        <Label fx:id="titleLabel" alignment="TOP_CENTER" prefHeight="62.0" prefWidth="448.0" text="Title" textAlignment="CENTER">
                           <font>
                              <Font size="42.0" />
                           </font>
                        </Label>
                        <Label fx:id="descriptionLabel" alignment="CENTER" prefHeight="300.0" prefWidth="422.0" text="Description" textAlignment="CENTER">
                           <font>
                              <Font name="Arial" size="25.0" />
                           </font>
                           <padding>
                              <Insets bottom="5.0" />
                           </padding>
                        </Label>
                        <Separator prefHeight="0.0" prefWidth="463.0" />
                        <HBox alignment="CENTER" prefHeight="154.0" prefWidth="463.0" spacing="30.0">
                           <padding>
                              <Insets bottom="2.0" left="10.0" right="10.0" top="2.0" />
                           </padding>
                           <children>
                              <Button fx:id="optionALabel" mnemonicParsing="false" onAction="#onOptAPress" prefHeight="120.0" prefWidth="210.0" text="Choice A" />
                              <Button fx:id="optionBLabel" mnemonicParsing="false" onAction="#onOptBPress" prefHeight="120.0" prefWidth="210.0" text="Choice B" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <VBox fx:id="resultVBox" alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Label fx:id="resultLabel" alignment="CENTER" prefHeight="300.0" prefWidth="422.0" text="Description" textAlignment="CENTER">
                           <font>
                              <Font name="Arial" size="25.0" />
                           </font>
                           <padding>
                              <Insets bottom="5.0" />
                           </padding>
                        </Label>
                        <Button fx:id="continueButton" mnemonicParsing="false" onAction="#onContinuePress" prefHeight="83.0" prefWidth="446.0" text="Continuar" textAlignment="CENTER">
                           <font>
                              <Font name="Arial Black" size="24.0" />
                           </font></Button>
                     </children>
                  </VBox>
               </children>
            </StackPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
